{#
 # Chip: pill-style control, button or link.
 #
 # @param string title The chip label.
 # @param string url Optional. If set, renders an <a> instead of <button>.
 # @param string target Optional. For links: '_self' or '_blank'.
 # @param array classes Additional CSS classes to apply to the chip. Optional.
 #}

{%- set classes = ( [ 
    active ? 'is-active', 
    'border [&.is-active]:bg-vert [&.is-active]:border-bleu [&.is-active]:text-bleu',
    mode == 'dark' ? 'text-beige bg-blanc/14 border-bleu/0' : 'text-bleu border-bleu', 
    '[backdrop-filter:blur(10px)]',
    'inline-flex items-center [text-box:trim-both cap alphabetic]',
    'px-2.5', 
    'py-2.25', 
    'lg:px-2.75', 
    'lg:py-[0.609375rem]',
    'rounded-6', 
    'text-button-m', 
    'border',
] | merge( classes | default( [] ) ) ) | join( ' ' ) -%}

{%- if url -%}
	<a href="{{ url }}" class="{{ classes }}" {% if target == '_blank' %} target="_blank" rel="noopener noreferrer" {% elseif target %} target="{{ target }}" {% endif %} {{ attributes ? attributes | map( ( value, key ) => value == '' ? key : "#{key}=\"#{value}\"" ) | join( ' ' ) | raw }}>
		{{- title -}}
	</a>
{%- else -%}
	<button type="button" class="{{ classes }}" {{ attributes ? attributes | map( ( value, key ) => value == '' ? key : "#{key}=\"#{value}\"" ) | join( ' ' ) | raw }}>
		{{- title -}}
	</button>
{%- endif -%}
