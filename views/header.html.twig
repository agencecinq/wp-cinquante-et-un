{#
 # Header
 #
 # @package Nexiode
 #}

<header
	role="banner"
	class="{{
	html_classes(
		'text-beige-nexiode container flex items-center gap-2.5 pt-5.25 pb-5 md:gap-5 lg:pt-8.5 lg:pb-4.5',
		'[reading-flow:flex-visual]',
		classes|default([])|join(' ')
	)
}}"
>
	<div class="flex flex-1 items-center gap-2.5 md:gap-5 lg:order-2 lg:justify-center">
		<cinq-drawer-button class="block lg:hidden">
			{% set icon_html %}
				{{-
					include(
						'svg/use.html.twig',
						{
							classes: ['size-5', 'block group-aria-expanded/drawer-button:hidden'],
							icon: 'bars'
						}
					)
				-}}
				{{-
					include(
						'svg/use.html.twig',
						{
							classes: ['size-5', 'hidden group-aria-expanded/drawer-button:block'],
							icon: 'times'
						}
					)
				-}}
			{% endset %}
			{{-
				include(
					'components/button.html.twig',
					{
						icon_html: icon_html,
						attributes: {
							'aria-controls': 'menu-drawer'
						},
						title: __('Menu', 'nexiode'),
						classes: ['group/drawer-button'],
						mode: 'dark',
						fill: 'text-blanc-nexiode',
						animate: false
					},
					with_context: false
				)
			-}}
		</cinq-drawer-button>

		{%- if nav_menus.main.get_items -%}
			<nav aria-label="{{ __('Main navigation', 'nexiode') }}" class="hidden lg:block">
				<ul
					itemscope
					class="text-button-m border-beige-nexiode/40 -mx-5 flex rounded-full border px-7.5"
					itemtype="http://schema.org/SiteNavigationElement"
				>
					{% for item in nav_menus.main.get_items() %}
						<li class="group">
							<a
								href="{{ item.url }}"
								itemprop="url"
								class="{{
								html_classes(
									item.current or ( 'current-menu-parent' in item.classes ) or ( 'current-page-ancestor' in item.classes )
										? 'text-vert-nexiode'
										: '',
									item.classes|default([])|join(' '),
									'hover:text-vert-nexiode group-focus-within:text-vert-nexiode group-hover:text-vert-nexiode block px-5 py-5.75'
								)
								}}"
								{{ item.children|length ? 'aria-haspopup="true"' }}
								{{
								item.is_target_blank or item.is_external
									? 'target="' ~ item.target ~ '" rel="noopener noreferer"'
								}}
							>
								{{- item.title -}}
							</a>

							{{-
								include(
									'components/nav-menu-items.html.twig',
									{
										title: item.title,
										url: item.url,
										id: item.id,
										items: item.children
									}
								)
							-}}
						</li>
					{% endfor %}
				</ul>
			</nav>
		{%- endif -%}
	</div>

	<a
		href="{{ site.link }}"
		class="mx-auto flex-none lg:order-1 lg:mx-0"
		aria-label="{{ site.name }}"
	>
		<img
			class="block h-6 w-auto lg:h-13"
			src="{{ asset('src/img/svg/logo.svg') }}"
			alt="{{ __("Nexiode's logo", 'nexiode') }}"
			width="177"
			height="52"
			loading="lazy"
		/>
		<span class="sr-only">{{- site.name -}}</span>
	</a>

	<div class="flex flex-1 justify-end gap-5 lg:order-3 lg:flex-none">
		{{-
			include(
				'components/button.html.twig',
				theme.contact.link
					|default({})
					|merge({
						classes: [],
						variant: 'tertiary',
						icon: 'arrow-right'
					}),
				with_context: false
			)
		-}}

		{%- if get_language_selector() -%}
			<div class="hidden lg:block">
				{{- include('components/language-selector.html.twig') -}}
			</div>
		{%- endif -%}
	</div>
</header>

{% embed 'components/drawer.html.twig'
	with {
		id: 'menu-drawer',
		classes: [],
		aria_label: __('Menu', 'nexiode')
	}
%}
	{% block content %}
		<cinq-mobile-menu class="text-bleu-nexiode max-w-182 mx-auto relative block h-full p-5">
			{{-
				include(
					'components/mobile-menu.html.twig',
					{
						items: nav_menus.main is defined ? nav_menus.main.get_items()|default([]) : []
					}
				)
			-}}
		</cinq-mobile-menu>
	{% endblock %}
{% endembed %}
