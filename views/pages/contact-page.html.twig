{#
 # Contact page
 #
 # @package WordPress
 # @subpackage WPCinquanteEtUn
 #}

{% extends 'index.html.twig' %}


{% import "macros/form.html.twig" as forms %}

{%- block content -%}
	<main id="content" role="main" aria-labelledby="contact-heading">
		<h1 id="contact-heading">{{- __( 'Contact Us', 'wp-cinquante-et-un' ) -}}</h1>

		<form method="post" action="" role="form" aria-describedby="contact-desc" novalidate>
			<p id="contact-desc" class="sr-only">{{- __( 'All fields marked with an asterisk (*) are required.', 'wp-cinquante-et-un' ) -}}</p>

			{{- forms.text( { id: 'name', label: __( 'Full name', 'wp-cinquante-et-un' ) ~ '&nbsp;' ~ '<span aria-hidden="true">*</span>', name: 'name', attributes: { required: '', 'aria-required': 'true', maxlength: '100' } } ) -}}
			{{- forms.text( { id: 'email', type: 'email', label: __( 'Email', 'wp-cinquante-et-un' ) ~ '&nbsp;' ~ '<span aria-hidden="true">*</span>', name: 'email', attributes: { required: '', 'aria-required': 'true', maxlength: '254' } } ) -}}
			{{- forms.text( { id: 'subject', type: 'subject', label: __( 'Subject', 'wp-cinquante-et-un' ), name: 'email', attributes: { maxlength: '150' } } ) -}}
			{{- forms.text( { id: 'phone', type: 'tel', label: __( 'Phone (optional)', 'wp-cinquante-et-un' ), name: 'phone', attributes: { inputmode: 'tel', maxlength: '30' } } ) -}}

			<div>
				<label for="message">{{- __( 'Message', 'wp-cinquante-et-un' ) -}}&nbsp;<span aria-hidden="true">*</span></label>
				<textarea id="message" name="message" rows="6" required aria-required="true" maxlength="2000"></textarea>
				<p id="message-help" class="sr-only">{{- __( 'Please include any details that will help us respond.', 'wp-cinquante-et-un' ) -}}</p>
			</div>

			<button type="submit">{{- __( 'Send message', 'wp-cinquante-et-un' ) -}}</button>
			<button type="reset">{{- __( 'Reset', 'wp-cinquante-et-un' ) -}}</button>
		</form>
	</main>
{%- endblock -%}
